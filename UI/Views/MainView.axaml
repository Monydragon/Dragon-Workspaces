<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:animation="clr-namespace:Avalonia.Animation;assembly=Avalonia.Base"
             xmlns:models="using:Dragon_Workspaces.Core.Models"
             xmlns:vm="using:Dragon_Workspaces.UI.ViewModels"
             x:Class="Dragon_Workspaces.UI.Views.MainView"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d"
             d:DesignWidth="1440"
             d:DesignHeight="900">
    <UserControl.DataTemplates>
        <DataTemplate x:DataType="vm:DashboardPlaceholder">
            <Border Padding="28"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="Workspace Inspector" />
                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{CompiledBinding Message}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:DataType="models:Project">
            <Border Padding="28"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid RowDefinitions="Auto,Auto,Auto,*"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="18"
                      ColumnSpacing="16">
                    <StackPanel Grid.Row="0" Spacing="8">
                        <TextBlock FontSize="30"
                                   FontWeight="Bold"
                                   Text="{CompiledBinding Name}" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{CompiledBinding Path}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="14,8"
                            Background="{StaticResource PanelAltBackgroundBrush}"
                            CornerRadius="14">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock FontWeight="Bold"
                                       Text="{CompiledBinding TypeIcon}" />
                            <TextBlock FontWeight="SemiBold"
                                       Text="{CompiledBinding WorkstationType}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="16">
                        <Border Grid.Column="0"
                                Padding="18"
                                Background="{StaticResource PanelBackgroundBrush}"
                                CornerRadius="18">
                            <StackPanel Spacing="6">
                                <TextBlock Foreground="{StaticResource CaptionTextBrush}" Text="Last Accessed" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{CompiledBinding LastAccessed, StringFormat='{}{0:MMM dd, yyyy HH:mm} UTC'}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="18"
                                Background="{StaticResource PanelBackgroundBrush}"
                                CornerRadius="18">
                            <StackPanel Spacing="6">
                                <TextBlock Foreground="{StaticResource CaptionTextBrush}" Text="Last Synced" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{CompiledBinding LastSynced, StringFormat='{}{0:MMM dd, yyyy HH:mm} UTC'}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Padding="18"
                            Background="{StaticResource PanelBackgroundBrush}"
                            CornerRadius="18">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Metadata" />
                            <ItemsControl ItemsSource="{CompiledBinding Metadata}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12"
                                                Margin="0,0,0,8"
                                                Background="{StaticResource PanelAltBackgroundBrush}"
                                                CornerRadius="12">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Key}" />
                                                <TextBlock Grid.Column="1"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding Value}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Grid.ColumnSpan="2"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="Dragon Workspaces keeps this workspace portable by storing platform-aware access tokens and enterprise-ready metadata." />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Border Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid IsVisible="{CompiledBinding IsDesktopLayout}"
                  Margin="20"
                  ColumnDefinitions="260,340,*"
                  ColumnSpacing="20">
                <Border Grid.Column="0"
                        Padding="20"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="24">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Bottom"
                                Height="44"
                                Margin="0,16,0,0"
                                Background="{StaticResource AccentBrush}"
                                Foreground="{StaticResource OnAccentBrush}"
                                CornerRadius="14"
                                Click="AddWorkspaceButton_OnClick">
                            Add Workspace
                        </Button>

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="26"
                                           FontWeight="Bold"
                                           Text="Dragon Workspaces" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Enterprise workspace hub for indie studios" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Foreground="{StaticResource CaptionTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="Navigation" />
                                <Button HorizontalAlignment="Stretch">Dashboard</Button>
                                <Button HorizontalAlignment="Stretch">Projects</Button>
                                <Button HorizontalAlignment="Stretch">Sync</Button>
                                <Button HorizontalAlignment="Stretch">Settings</Button>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{StaticResource CaptionTextBrush}"
                                           Text="Workspace List" />
                                <TextBlock FontSize="24"
                                           FontWeight="Bold"
                                           Text="{Binding Projects.Count, StringFormat='{}{0} Active Workspaces'}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="12,8"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource PanelAltBackgroundBrush}"
                                    CornerRadius="12">
                                <TextBlock FontWeight="SemiBold"
                                           Text="Synced" />
                            </Border>
                        </Grid>

                        <ListBox ItemsSource="{Binding Projects}"
                                 SelectedItem="{Binding SelectedProject}"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Project">
                                    <Border Classes="project-card"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Cursor="Hand">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">
                                            <Border Width="40"
                                                    Height="40"
                                                    Background="{StaticResource PanelBackgroundBrush}"
                                                    CornerRadius="12">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"
                                                           Text="{CompiledBinding TypeIcon}" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock FontWeight="Bold"
                                                           Text="{CompiledBinding Name}" />
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{CompiledBinding Path}" />
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource CaptionTextBrush}"
                                                           Text="{CompiledBinding LastSynced, StringFormat='Synced {0:MMM dd HH:mm}'}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2"
                      RowDefinitions="Auto,*"
                      RowSpacing="20">
                    <Border Padding="24"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource MutedBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="24">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock Foreground="{StaticResource CaptionTextBrush}"
                                           Text="Inspector" />
                                <TextBlock FontSize="32"
                                           FontWeight="Bold"
                                           Text="Workspace intelligence at a glance" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="14,8"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource PanelAltBackgroundBrush}"
                                    CornerRadius="14">
                                <TextBlock FontWeight="SemiBold"
                                           Text="Cross-Platform" />
                            </Border>
                        </Grid>
                    </Border>

                    <TransitioningContentControl Grid.Row="1"
                                                 Content="{Binding CurrentContent}">
                        <TransitioningContentControl.PageTransition>
                            <animation:CrossFade Duration="0:0:0.25" />
                        </TransitioningContentControl.PageTransition>
                    </TransitioningContentControl>
                </Grid>
            </Grid>

            <Grid IsVisible="{CompiledBinding IsMobileLayout}"
                  RowDefinitions="Auto,*,Auto">
                <Border Padding="20,16"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="24"
                                       FontWeight="Bold"
                                       Text="Dragon Workspaces" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       Text="Mobile workspace command center" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="120"
                                Background="{StaticResource AccentBrush}"
                                Foreground="{StaticResource OnAccentBrush}"
                                CornerRadius="14"
                                Click="AddWorkspaceButton_OnClick">
                            Add Workspace
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16"
                                Spacing="16">
                        <Border Padding="20"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24">
                            <StackPanel Spacing="8">
                                <TextBlock Foreground="{StaticResource CaptionTextBrush}"
                                           Text="Today" />
                                <TextBlock FontSize="28"
                                           FontWeight="Bold"
                                           Text="{Binding Projects.Count, StringFormat='{}{0} Workspace(s) Ready'}" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Your Android shell prioritizes quick import, workspace review, and lightweight inspection." />
                            </StackPanel>
                        </Border>

                        <Border Padding="20"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource MutedBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="22"
                                           FontWeight="Bold"
                                           Text="Workspaces" />
                                <ListBox ItemsSource="{Binding Projects}"
                                         SelectedItem="{Binding SelectedProject}"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Project">
                                            <Border Classes="project-card"
                                                    Padding="14"
                                                    Margin="0,0,0,10">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontWeight="Bold"
                                                               Text="{CompiledBinding Name}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="{CompiledBinding Path}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource CaptionTextBrush}"
                                                               Text="{CompiledBinding WorkstationType}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <TransitioningContentControl Content="{Binding CurrentContent}">
                            <TransitioningContentControl.PageTransition>
                                <animation:CrossFade Duration="0:0:0.25" />
                            </TransitioningContentControl.PageTransition>
                        </TransitioningContentControl>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="12"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1,1,1,0">
                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="12">
                        <Button Grid.Column="0">Home</Button>
                        <Button Grid.Column="1">Workspaces</Button>
                        <Button Grid.Column="2">Profile</Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
